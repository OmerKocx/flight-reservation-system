<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="omerkoc">
        <createTable tableName="bookings">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_code" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="customer_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="flight_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="booking_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="omerkoc">
        <createSequence sequenceName="booking_seq" startValue="1" incrementBy="1"/>
    </changeSet>

</databaseChangeLog>
